# ==============================================================================
# Unwind Project Configuration Template
# Copy this file to .env in your root (or separate apps as needed) and configure.
# ==============================================================================

# --- Backend Configuration ---
BACKEND_PORT=8000
BACKEND_HOST=127.0.0.1
DATABASE_URL=sqlite:///./unwind.db

# Security & Authentication (JWT-ready skeleton config)
# Generate a secure key in production: openssl rand -hex 32
JWT_SECRET_KEY=your_super_secret_jwt_key_placeholder_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Frontend Configuration ---
VITE_API_URL=http://localhost:8000/api/v1
